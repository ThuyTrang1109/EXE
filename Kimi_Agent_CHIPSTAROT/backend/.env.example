# ========================
# CHIPSTAROT BACKEND - Environment Variables
# Copy to .env và điền đủ giá trị trước khi chạy
# KHÔNG COMMIT file .env vào Git!
# ========================

# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=chipstarot_db;Username=postgres;Password=YOUR_STRONG_PASSWORD

# JWT
Jwt__Secret=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
Jwt__Issuer=chipstarot-api
Jwt__Audience=chipstarot-app
Jwt__AccessTokenExpireMinutes=60
Jwt__RefreshTokenExpireDays=30

# Email (Gmail App Password)
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__FromEmail=your-gmail@gmail.com
Email__FromPassword=your-gmail-app-password
Email__FromName=CHIPSTAROT

# CORS
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=https://chipstarot.com
